# Copy to .env.local for local runs (never commit real values). See README.md for what
# each key is for and where its Railway-side counterpart comes from.

# The app-only X stream credential. Used RAW — never URL-decode the portal's %2B/%3D
# escapes, decoding produces a 401. Distinct from X_CLIENT_ID/X_CLIENT_SECRET.
X_BEARER_TOKEN=

# The app's /api/ingest URL, e.g. https://oparax.ai/api/ingest (or a localhost URL for
# local testing against `pnpm dev` in the app repo). Kept as a variable, never hardcoded.
INGEST_URL=

# Must be byte-identical to the app's INGEST_SECRET (Vercel env). A mismatch is a 401 on
# every delivery, which this worker treats as fatal.
INGEST_SECRET=

# Supabase project URL + a service-role key (read-only usage here: rule sync reads
# experiments.tracked_handles, the cap alarm reads usage_events). Same project as the app;
# distinct env var names because this package never imports the app's lib/supabase clients.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Slack incoming webhook for the liveness + 80%-of-observed-cap alarms.
SLACK_WEBHOOK_URL=

# Optional tuning (sane defaults if unset — see README "Env vars").
INGEST_OBSERVED_DAILY_CAP=2000
INGEST_RULE_SYNC_INTERVAL_MS=300000
INGEST_LIVENESS_TIMEOUT_MS=90000
INGEST_ALARM_COOLDOWN_MS=3600000
