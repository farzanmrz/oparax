{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "fluid": true,
  "regions": ["iad1", "sfo1"],
  "crons": [],
  "git": {
    "deploymentEnabled": {
      "ft/**": false,
      "codex-ft*/**": false,
      "feature/**": false,
      "feat/**": false,
      "fix/**": false,
      "chore/**": false
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
