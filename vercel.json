{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "fluid": true,
  "regions": ["iad1", "sfo1"],
  "crons": [],
  "git": {
    "deploymentEnabled": {
      "ft/**": false,
      "codex-ft*/**": false,
      "feature/**": false,
      "feat/**": false,
      "fix/**": false,
      "chore/**": false
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "oparax-chirp-farzanmrzs-projects.vercel.app"
        }
      ],
      "destination": "https://oparax.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "oparax-chirp.vercel.app" }],
      "destination": "https://oparax.ai/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
