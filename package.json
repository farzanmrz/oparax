{
  "name": "oparax-chirp-root",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.cjs",
    "postinstall": "CI=true pnpm --dir frontend install",
    "install:frontend": "pnpm --dir frontend install",
    "dev": "pnpm --dir frontend dev",
    "build": "pnpm --dir frontend build",
    "start": "pnpm --dir frontend start",
    "lint": "pnpm --dir frontend lint",
    "test": "pnpm --dir frontend test",
    "test:watch": "pnpm --dir frontend test:watch"
  },
  "devDependencies": {
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  }
}
